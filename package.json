{
  "name": "sem-ir-app",
  "version": "1.0.0",
  "description": "SEM IR App",
  "scripts": {
    "lint": "pnpm run lint --prefix client && pnpm run lint --prefix server",
    "lint:fix": "echo \"lint:fix not implemented\"",
    "install:client": "cd client && pnpm install && cd ..",
    "install:server": "cd server && pnpm install && cd ..",
    "install": "pnpm run install:client && pnpm run install:server",
    "dev:client": "cd client && pnpm start && cd ..",
    "dev:server": "cd server && pnpm run dev && cd ..",
    "dev": "concurrently --kill-others-on-fail \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "test": "cd server && pnpm test && cd ..",
    "clean": "rm -rf node_modules && cd client && rm -rf node_modules && cd .. && cd server && rm -rf node_modules && cd ..",
    "reinstall": "pnpm run clean && pnpm install",
    "format": "cd client && pnpm run format && cd .. && cd server && pnpm run format && cd .."
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-alpha.6",
    "@google-cloud/storage": "^7.15.2",
    "@mapbox/mapbox-gl-draw": "^1.5.0",
    "@mapbox/search-js-react": "^1.0.0",
    "@types/mapbox-gl": "^3.4.1",
    "concurrently": "^5.3.0",
    "launchdarkly-react-client-sdk": "^3.6.1",
    "mapbox-gl": "^3.10.0",
    "react-beautiful-dnd": "^13.1.1",
    "styled-components": "^6.0.7"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3",
    "@types/react-beautiful-dnd": "^13.1.4",
    "@types/styled-components": "^5.1.26"
  }
}
